    if #t1~=#t2 return false end
    for key,value in pairs(t1)
      if type(value)=="table" and type(t2[key])=="table"
        if not equal2(value,t2[key])
          return false
        end
       else
        if value~=t2[key]
          return false
        end
      end
    end
    return true
  end
```

</details>

```lua
  for _,eachTable in ipairs{...}
    if not equal2({...}[1],eachTable) then
      return false
